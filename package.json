  ],
  "author": "Pranab Sarkar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spranab/agent-bridge.git"
  },
  "homepage": "https://github.com/spranab/agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/spranab/agent-bridge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "README.md",
    "CLAUDE.md",
    "CLAUDE_SNIPPET.md",
    "LICENSE"
  ],
  "dependencies": {
